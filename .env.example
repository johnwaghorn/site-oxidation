# Bridge gateway IPs of Docker Desktop's compose networks.
# Ref: https://docs.docker.com/engine/network/#subnet-allocation
BOOTSTRAP_TRUSTED_IPS=172.64.154.55,172.67.197.85
# COOKIE_SECURE: true using TLS, false for direct HTTP access on a trusted LAN.
COOKIE_SECURE=false
ENABLE_SWAGGER_UI=true
TZ=Etc/UTC
